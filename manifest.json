{
  "manifest_version": 3,
  "name": "DOM to SVG Exporter",
  "version": "1.0.0",
  "description": "Capture any UI element on a webpage and export it as SVG or send to Figma",

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "downloads",
    "storage",
    "identity",
    "clipboardWrite"
  ],

  "host_permissions": [
    "https://api.figma.com/*",
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "oauth2": {
    "client_id": "YOUR_FIGMA_CLIENT_ID_HERE",
    "scopes": ["file_read"]
  }
}
